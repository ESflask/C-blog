{
  "app": {
    "threads_num": 4,
    "document_root": "./static",
    "upload_path": "./uploads",
    "log": {
      "log_path": "./logs",
      "log_level": "DEBUG"
    },
    "run_as_daemon": false,
    "relaunch_on_error": false,
    "use_sendfile": true,
    "use_gzip": true,
    "session": {
      "enabled": true,
      "timeout": 1209600
    }
  },
  "listeners": [
    {
      "address": "0.0.0.0",
      "port": 8080,
      "https": false
    }
  ],
  "db_clients": [
    {
      "name": "default",
      "rdbms": "sqlite3",
      "filename": "./blog.db",
      "connection_number": 1,
      "is_fast": false
    }
  ]
}
